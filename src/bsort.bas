#RetroDevStudio.MetaData.BASIC:2049,BASIC V2,uppercase,10,10
10 OPEN 1,8,2,"BSORT,S,W"
20 PRINT# 1, "(* PGM -- SORTING BY BINARY TREE *)"
30 PRINT# 1, "VAR I,J,K,N,NEW:INTEGER;"
40 PRINT# 1, "T,L,R,S:ARRAY[110] OF INTEGER;"
50 PRINT# 1, " "
60 PRINT# 1, "PROC ENTER(N);"
70 PRINT# 1, " VAR J:INTEGER;"
80 PRINT# 1, " BEGIN J:=0;"
90 PRINT# 1, "  REPEAT"
100 PRINT# 1,"   IF N<=T[J] THEN"
110 PRINT# 1,"     IF L[J]<>0 THEN J:=L[J]"
120 PRINT# 1,"     ELSE BEGIN L[J]:=NEW;J:=0 END"
130 PRINT# 1,"   ELSE IF R[J]<>0 THEN J:=R[J]"
140 PRINT# 1,"        ELSE BEGIN R[J]:=NEW;J:=0 END"
150 PRINT# 1,"  UNTIL J=0;"
160 PRINT# 1,"  T[NEW]:=N;NEW:=NEW+1"
170 PRINT# 1," END;"
180 PRINT# 1," "
190 PRINT# 1,"PROC TRAV(J); (* TRAVERSE THE TREE *)"
200 PRINT# 1," BEGIN IF L[J]<>0 THEN TRAV(L[J]);"
210 PRINT# 1,"  S[K]:=T[J];K:=K+1;"
220 PRINT# 1,"  IF R[J]<>0 THEN TRAV(R[J])"
230 PRINT# 1," END;"
240 PRINT# 1," "
250 PRINT# 1,"BEGIN (* MAIN *)"
260 PRINT# 1," T[0]:=255;NEW:=0;"
270 PRINT# 1," READ(K#);WRITE(13,10);"
280 PRINT# 1," FOR I:=0 TO K DO BEGIN"
290 PRINT# 1,"  L[I]:=0;R[I]:=0; ENTER(MEM[I+%1A00]) END;"
300 PRINT# 1," K:=0; TRAV(0);"
310 PRINT# 1," FOR I:=0 TO K-1 DO WRITE(' ',S[I]#);"
320 PRINT# 1," WRITE(13,10)"
330 PRINT# 1,"END."
500 CLOSE 1