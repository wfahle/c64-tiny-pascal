#RetroDevStudio.MetaData.BASIC:2049,BASIC V2,uppercase,10,10
10 OPEN 1,8,2,"SAMPLE,S,W"
20 PRINT#1,"CONST CR=13;LF=10;"
30 PRINT#1,"VAR A,B,C,D:INTEGER;"
40 PRINT#1,"FUNC MAX4(X1,X2,X3,X4): (*LARGEST OF 4 NUMBERS*)"
50 PRINT#1,"   FUNC MAX2(X1,X2): (* LARGEST OF 2 NUMBERS *)"
60 PRINT#1,"      BEGIN"
70 PRINT#1,"         IF X1>X2 THEN MAX2:=X1"
80 PRINT#1,"         ELSE MAX2:=X2"
90 PRINT#1,"      END;"
100 PRINT#1,"   BEGIN"
110 PRINT#1,"      MAX4:=MAX2(MAX2(X1,X2),MAX2(X3,X4))"
120 PRINT#1,"   END;"
130 PRINT#1,"BEGIN"
140 PRINT#1,"   REPEAT"
150 PRINT#1,"      READ(A#,B#,C#,D#);"
160 PRINT#1,"      WRITE ('THE LARGEST IS',MAX4(A,B,C,D)#,CR,LF)"
170 PRINT#1,"   UNTIL A<0"
180 PRINT#1,"END."
190 CLOSE 1